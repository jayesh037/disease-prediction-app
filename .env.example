# .env.example
# -----------------------------------------------------------------------
# Copy this file to .env (backend) and set actual values before running.
# Never commit .env to version control.
# -----------------------------------------------------------------------

# ── Backend (used by FastAPI / Uvicorn) ──────────────────────────────────
MODEL_PATH=./models/hybrid_dl.h5
SCALER_PATH=./models/scaler.pkl

# ── Frontend (used by Vite at build time) ────────────────────────────────
# Set this to your Render backend URL in Vercel environment settings.
# In local dev you do NOT need this — Vite's /api proxy handles routing.
VITE_API_URL=https://your-backend.onrender.com
